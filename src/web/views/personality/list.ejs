<%- include('../layout', { body: `
<div class="page">
  <div class="page-header">
    <div class="page-header-content">
      <h1 class="page-title">Personality Packs</h1>
      <p class="page-subtitle">Manage themed response packs for your bot</p>
    </div>
    <div class="page-header-actions">
      <a href="/personality/new" class="btn btn-primary">Create New Pack</a>
    </div>
  </div>

  <div class="page-content">
    ${typeof packs !== 'undefined' && packs.length > 0 ? `
    <div class="table-container">
      <table class="table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Status</th>
            <th>Templates</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          ${packs.map(pack => {
            const escapeHtml = (str) => {
              if (!str) return '';
              return String(str)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
            };
            const packName = escapeHtml(pack.name);
            const packDesc = escapeHtml(pack.description);
            const isActive = pack.active_channel_count > 0;
            const statusText = isActive ? 'Active on ' + pack.active_channel_count + ' channel' + (pack.active_channel_count > 1 ? 's' : '') : 'Inactive';
            return '<tr>' +
              '<td>' +
                '<div class="text-primary font-medium">' + packName + (pack.is_default ? ' <span class="badge badge-info">Default</span>' : '') + '</div>' +
                (packDesc ? '<div class="text-secondary text-sm">' + packDesc + '</div>' : '') +
              '</td>' +
              '<td><span class="badge ' + (isActive ? 'badge-success' : 'badge-secondary') + '">' + statusText + '</span></td>' +
              '<td>' + pack.template_count + '</td>' +
              '<td class="actions-cell">' +
                '<a href="/personality/' + pack.id + '" class="btn btn-sm">Edit</a> ' +
                '<form action="/personality/' + pack.id + '/duplicate" method="POST" style="display:inline">' +
                  '<input type="hidden" name="_csrf" value="' + csrfToken + '">' +
                  '<button type="submit" class="btn btn-sm btn-secondary">Duplicate</button>' +
                '</form> ' +
                '<a href="/personality/' + pack.id + '/export" class="btn btn-sm btn-secondary">Export</a> ' +
                (!pack.is_default ? '<form action="/personality/' + pack.id + '/delete" method="POST" style="display:inline" onsubmit="return confirm(' + "'Are you sure you want to delete this pack?" + (isActive ? ' It is active on ' + pack.active_channel_count + ' channel(s) which will be deactivated.' : '') + "'" + ')">' +
                  '<input type="hidden" name="_csrf" value="' + csrfToken + '">' +
                  '<button type="submit" class="btn btn-sm btn-danger">Delete</button>' +
                '</form>' : '') +
              '</td>' +
            '</tr>';
          }).join('')}
        </tbody>
      </table>
    </div>

    <div class="card mt-6">
      <div class="card-header">
        <h3 class="card-title">Import Pack</h3>
      </div>
      <div class="card-body">
        <form action="/personality/import" method="POST">
          <input type="hidden" name="_csrf" value="${csrfToken}">
          <div class="form-group">
            <label for="importData" class="form-label">Paste JSON data</label>
            <textarea id="importData" name="importData" class="form-input" rows="4" placeholder='{"name": "My Pack", "templates": {...}}'></textarea>
            <p class="form-hint">Paste the contents of an exported personality pack JSON file</p>
          </div>
          <button type="submit" class="btn btn-secondary">Import</button>
        </form>
      </div>
    </div>
    ` : `
    <div class="card">
      <div class="card-body">
        <div class="empty-state">
          <p>No personality packs yet. Create your first pack to theme your bot's messages.</p>
          <a href="/personality/new" class="btn btn-primary mt-2">Create New Pack</a>
        </div>
      </div>
    </div>
    `}
  </div>
</div>
`, activePage: 'personality' }) %>
